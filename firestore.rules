rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isExpectedAppId(appId) {
      return appId == 'tecnopan-inventory-app';
    }

    function fallbackStaffEmails() {
      return [
        'joe.barrettoburns@gmail.com',
        'sahjin.ribeiro@gmail.com'
      ];
    }

    // Safely extract the email from the auth token
    function getEmail() {
      let token = request.auth.token;
      let hasEmail = token != null && 'email' in token && token.email is string && token.email != '';
      let hasIdentityEmail = token != null && 'firebase' in token && 
                             'identities' in token.firebase && 
                             'email' in token.firebase.identities && 
                             token.firebase.identities.email is list && 
                             token.firebase.identities.email.size() > 0 && 
                             token.firebase.identities.email[0] is string;
                             
      return hasEmail ? token.email.lower() : (hasIdentityEmail ? token.firebase.identities.email[0].lower() : '');
    }

    // Check if the email is in the provided list, accounting for gmail/googlemail aliases
    function isEmailAllowed(email, allowedList) {
      return email in allowedList || 
             (email.matches('.*@gmail\\.com') && email.replace('@gmail\\.com', '@googlemail.com') in allowedList) || 
             (email.matches('.*@googlemail\\.com') && email.replace('@googlemail\\.com', '@gmail.com') in allowedList);
    }

    function isFallbackStaff() {
      let email = getEmail();
      return email != '' && isEmailAllowed(email, fallbackStaffEmails());
    }

    function isAllowlisted() {
      let email = getEmail();
      let docPath = /databases/$(database)/documents/artifacts/tecnopan-inventory-app/config/access_allowlist;
      let allowlistDoc = get(docPath);
      
      return email != '' &&
             allowlistDoc != null &&
             'emails' in allowlistDoc.data && 
             allowlistDoc.data.emails is list &&
             isEmailAllowed(email, allowlistDoc.data.emails);
    }

    // Main access check: user must be signed in, have an email, and be in either list
    function hasAccess(appId) {
      return request.auth != null && 
             isExpectedAppId(appId) && 
             (isFallbackStaff() || isAllowlisted());
    }

    // Allow any authenticated user to read/write the allowlist so the client can self-heal casing mismatches
    match /artifacts/{appId}/config/access_allowlist {
      allow read, write: if request.auth != null && isExpectedAppId(appId);
    }

    // Protect all actual app data
    match /artifacts/{appId}/public/data/{document=**} {
      allow read, write: if hasAccess(appId);
    }
  }
}